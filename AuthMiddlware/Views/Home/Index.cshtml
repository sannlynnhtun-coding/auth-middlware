@model HomeDashboardViewModel
@{
    ViewData["Title"] = "Auth Dashboard";
    var tokenToDisplay = Model.JwtTokenMasked ?? "No token yet";
}

<div class="space-y-6">
    <section class="rounded-3xl border border-slate-200/80 bg-white/85 p-6 shadow-lg shadow-blue-100/50 sm:p-8">
        <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
                <h1 class="text-3xl font-bold tracking-tight text-slate-900">Auth Flow Dashboard</h1>
                <p class="mt-2 max-w-2xl text-sm text-slate-600">This page shows exactly what happened after sign-in: session, cookie, token, and decoded claims from the JWT.</p>
            </div>
            <a asp-controller="SignIn" asp-action="Index" class="rounded-xl bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-blue-700">Run Demo Again</a>
        </div>

        <div class="mt-6 grid gap-4 md:grid-cols-3">
            <article class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
                <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Session Email</p>
                <p class="mono mt-2 break-all text-sm text-slate-900">@(Model.SessionEmail ?? "(empty)")</p>
                <p class="mt-2 text-xs @(Model.HasSessionEmail ? "text-emerald-700" : "text-rose-600")">@(Model.HasSessionEmail ? "Available" : "Missing")</p>
            </article>

            <article class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
                <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Cookie Email</p>
                <p class="mono mt-2 break-all text-sm text-slate-900">@(Model.CookieEmail ?? "(empty)")</p>
                <p class="mt-2 text-xs @(Model.HasCookieEmail ? "text-emerald-700" : "text-rose-600")">@(Model.HasCookieEmail ? "Available" : "Missing")</p>
            </article>

            <article class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
                <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">JWT Token</p>
                <p id="masked-token" class="mono mt-2 break-all text-xs text-slate-900">@tokenToDisplay</p>
                <p id="full-token" class="mono mt-2 hidden break-all rounded-lg bg-slate-900/95 p-3 text-xs text-emerald-200">@Model.JwtTokenRaw</p>
                <div class="mt-3 flex flex-wrap gap-2">
                    <button id="toggle-token" type="button" class="rounded-lg border border-slate-300 px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-100">Show Full Token</button>
                    <button id="copy-token" type="button" class="rounded-lg border border-slate-300 px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-100">Copy Token</button>
                </div>
            </article>
        </div>
    </section>

    <section class="grid gap-6 lg:grid-cols-2">
        <article class="rounded-3xl border border-slate-200/80 bg-white/85 p-6 shadow-lg shadow-blue-100/50 sm:p-8">
            <h2 class="text-xl font-semibold text-slate-900">Decoded JWT Claims</h2>
            <p class="mt-2 text-sm text-slate-600">@Model.JwtDecodeMessage</p>

            @if (Model.JwtDecodeSuccess && Model.Claims.Count > 0)
            {
                <div class="mt-4 overflow-hidden rounded-2xl border border-slate-200">
                    <table class="w-full table-fixed border-collapse text-left text-sm">
                        <thead class="bg-slate-100 text-slate-700">
                            <tr>
                                <th class="w-1/3 px-4 py-3 font-semibold">Claim Type</th>
                                <th class="px-4 py-3 font-semibold">Claim Value</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var claim in Model.Claims)
                        {
                            <tr class="border-t border-slate-200 bg-white align-top">
                                <td class="mono px-4 py-3 text-xs text-slate-700">@claim.Type</td>
                                <td class="mono break-all px-4 py-3 text-xs text-slate-900">@claim.Value</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="mt-4 rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-6 text-sm text-slate-600">
                    No claims to display yet. Click <span class="font-semibold">Run Demo Again</span> to generate a fresh token.
                </div>
            }
        </article>

        <article class="rounded-3xl border border-slate-200/80 bg-white/85 p-6 shadow-lg shadow-blue-100/50 sm:p-8">
            <h2 class="text-xl font-semibold text-slate-900">How This Demo Works</h2>
            <ol class="mt-4 space-y-3 text-sm text-slate-700">
                <li class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3"><span class="font-semibold">1.</span> You click demo sign-in with prefilled credentials.</li>
                <li class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3"><span class="font-semibold">2.</span> Server issues session + cookie + jwt_token.</li>
                <li class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3"><span class="font-semibold">3.</span> Controller attribute filters validate token/cookie/session per controller.</li>
                <li class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3"><span class="font-semibold">4.</span> This page decodes jwt_token and shows claim values.</li>
            </ol>

            <div class="mt-5 grid gap-3 sm:grid-cols-3">
                <button type="button" data-filter-check data-endpoint="/CookieTest/Protected" data-filter="cookie" class="rounded-xl border border-blue-200 bg-blue-50 px-3 py-2 text-center text-xs font-semibold text-blue-700 hover:bg-blue-100 disabled:cursor-not-allowed disabled:opacity-60">Try Cookie Filter</button>
                <button type="button" data-filter-check data-endpoint="/SessionTest/Protected" data-filter="session" class="rounded-xl border border-teal-200 bg-teal-50 px-3 py-2 text-center text-xs font-semibold text-teal-700 hover:bg-teal-100 disabled:cursor-not-allowed disabled:opacity-60">Try Session Filter</button>
                <button type="button" data-filter-check data-endpoint="/JwtTest/Protected" data-filter="jwt" class="rounded-xl border border-indigo-200 bg-indigo-50 px-3 py-2 text-center text-xs font-semibold text-indigo-700 hover:bg-indigo-100 disabled:cursor-not-allowed disabled:opacity-60">Try JWT Filter</button>
            </div>

            <div id="filter-status-card" class="mt-4 rounded-2xl border border-slate-200 bg-slate-50 p-4">
                <div class="flex items-start justify-between gap-3">
                    <div class="flex items-start gap-3">
                        <span id="status-icon-neutral" class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-slate-200 text-slate-700">
                            <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 8v4m0 4h.01" /><circle cx="12" cy="12" r="9"/></svg>
                        </span>
                        <span id="status-icon-success" class="hidden inline-flex h-8 w-8 items-center justify-center rounded-full bg-emerald-100 text-emerald-700">
                            <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2"><path d="m5 13 4 4L19 7"/><circle cx="12" cy="12" r="9"/></svg>
                        </span>
                        <span id="status-icon-fail" class="hidden inline-flex h-8 w-8 items-center justify-center rounded-full bg-rose-100 text-rose-700">
                            <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 9-6 6m0-6 6 6"/><circle cx="12" cy="12" r="9"/></svg>
                        </span>
                        <div>
                            <p id="status-title" class="text-sm font-semibold text-slate-900">No check yet</p>
                            <p id="status-message" class="mt-1 text-xs text-slate-600">Click any Try button to get JSON success/fail result.</p>
                            <p id="status-meta" class="mono mt-2 text-[11px] text-slate-500">last-check: not-run</p>
                        </div>
                    </div>
                    <button type="button" id="retry-check" class="rounded-lg border border-slate-300 px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-100 disabled:cursor-not-allowed disabled:opacity-60" disabled>Retry</button>
                </div>
            </div>
        </article>
    </section>
</div>

@section Scripts {
<script>
(() => {
    const toggleButton = document.getElementById('toggle-token');
    const copyButton = document.getElementById('copy-token');
    const masked = document.getElementById('masked-token');
    const full = document.getElementById('full-token');

    const checkButtons = Array.from(document.querySelectorAll('[data-filter-check]'));
    const retryButton = document.getElementById('retry-check');
    const statusCard = document.getElementById('filter-status-card');
    const statusTitle = document.getElementById('status-title');
    const statusMessage = document.getElementById('status-message');
    const statusMeta = document.getElementById('status-meta');
    const neutralIcon = document.getElementById('status-icon-neutral');
    const successIcon = document.getElementById('status-icon-success');
    const failIcon = document.getElementById('status-icon-fail');

    let lastCheck = null;

    function setButtonsDisabled(disabled) {
        checkButtons.forEach((btn) => {
            btn.disabled = disabled;
        });

        retryButton.disabled = disabled || !lastCheck;
    }

    function showStatus(result) {
        const isSuccess = Boolean(result.success);
        statusCard.className = isSuccess
            ? 'mt-4 rounded-2xl border border-emerald-200 bg-emerald-50 p-4'
            : 'mt-4 rounded-2xl border border-rose-200 bg-rose-50 p-4';

        neutralIcon.classList.add('hidden');
        successIcon.classList.toggle('hidden', !isSuccess);
        failIcon.classList.toggle('hidden', isSuccess);

        statusTitle.textContent = isSuccess ? 'Check Succeeded' : 'Check Failed';
        statusMessage.textContent = result.message || (isSuccess ? 'Request succeeded.' : 'Request failed.');

        const when = result.timestampUtc ? new Date(result.timestampUtc).toLocaleTimeString() : new Date().toLocaleTimeString();
        const code = result.statusCode || (isSuccess ? 200 : 401);
        statusMeta.textContent = `filter=${result.filter || 'unknown'} | status=${code} | time=${when}`;
    }

    async function runFilterCheck(endpoint, filterName) {
        setButtonsDisabled(true);

        try {
            const response = await fetch(endpoint, {
                method: 'GET',
                headers: {
                    'Accept': 'application/json'
                }
            });

            let body;
            const contentType = response.headers.get('content-type') || '';
            if (contentType.includes('application/json')) {
                body = await response.json();
            } else {
                body = {
                    success: false,
                    filter: filterName,
                    message: 'Unexpected non-JSON response.',
                    statusCode: response.status,
                    timestampUtc: new Date().toISOString()
                };
            }

            if (typeof body.success !== 'boolean') {
                body.success = response.ok;
            }

            if (!body.filter) {
                body.filter = filterName;
            }

            if (!body.statusCode) {
                body.statusCode = response.status;
            }

            if (!body.timestampUtc) {
                body.timestampUtc = new Date().toISOString();
            }

            showStatus(body);
        } catch {
            showStatus({
                success: false,
                filter: filterName,
                message: 'Network error. Please retry.',
                statusCode: 0,
                timestampUtc: new Date().toISOString()
            });
        } finally {
            setButtonsDisabled(false);
        }
    }

    checkButtons.forEach((button) => {
        button.addEventListener('click', () => {
            const endpoint = button.dataset.endpoint;
            const filter = button.dataset.filter || 'unknown';
            lastCheck = { endpoint, filter };
            retryButton.disabled = false;
            runFilterCheck(endpoint, filter);
        });
    });

    retryButton?.addEventListener('click', () => {
        if (!lastCheck) {
            return;
        }

        runFilterCheck(lastCheck.endpoint, lastCheck.filter);
    });

    toggleButton?.addEventListener('click', () => {
        const showing = !full.classList.contains('hidden');
        if (showing) {
            full.classList.add('hidden');
            masked.classList.remove('hidden');
            toggleButton.textContent = 'Show Full Token';
        } else {
            full.classList.remove('hidden');
            masked.classList.add('hidden');
            toggleButton.textContent = 'Hide Full Token';
        }
    });

    copyButton?.addEventListener('click', async () => {
        const text = (full?.textContent || '').trim();
        if (!text) {
            copyButton.textContent = 'No Token';
            setTimeout(() => copyButton.textContent = 'Copy Token', 1200);
            return;
        }

        try {
            await navigator.clipboard.writeText(text);
            copyButton.textContent = 'Copied';
            setTimeout(() => copyButton.textContent = 'Copy Token', 1200);
        } catch {
            copyButton.textContent = 'Copy Failed';
            setTimeout(() => copyButton.textContent = 'Copy Token', 1200);
        }
    });
})();
</script>
}
