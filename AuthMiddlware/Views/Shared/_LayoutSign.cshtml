<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sign In Demo</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --ink: #071129;
            --sky: #ecf4ff;
            --mist: #f8fbff;
        }

        body {
            font-family: 'Space Grotesk', sans-serif;
            color: var(--ink);
            background: radial-gradient(circle at 20% 0%, #dbeafe 0%, #f8fbff 45%, #f0f7ff 100%);
        }

        .mono {
            font-family: 'IBM Plex Mono', monospace;
        }
    </style>
</head>
<body class="min-h-screen">
    <div class="mx-auto flex min-h-screen max-w-6xl flex-col px-4 py-8 sm:px-6">
        <div class="mb-8 flex items-center justify-between">
            <a asp-controller="Home" asp-action="Index" class="inline-flex items-center gap-2 rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-900 transition hover:bg-slate-50">
                <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-blue-600 text-white">A</span>
                Auth Learning Lab
            </a>
            <a asp-controller="Home" asp-action="Privacy" class="rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50">How It Works</a>
        </div>

        <div class="flex flex-1 items-center justify-center">
            @RenderBody()
        </div>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
