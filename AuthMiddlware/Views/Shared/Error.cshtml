@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="mx-auto max-w-3xl rounded-3xl border border-rose-200 bg-rose-50/80 p-6 shadow-lg shadow-rose-100 sm:p-8">
    <h1 class="text-2xl font-bold text-rose-700">Something Went Wrong</h1>
    <p class="mt-2 text-sm text-rose-700/90">An unexpected error occurred while processing your request.</p>

    @if (Model.ShowRequestId)
    {
        <p class="mono mt-4 rounded-lg bg-white px-3 py-2 text-xs text-slate-700">
            Request ID: @Model.RequestId
        </p>
    }

    <p class="mt-5 text-sm text-slate-700">
        For local debugging, use <span class="mono">ASPNETCORE_ENVIRONMENT=Development</span> to see detailed errors.
    </p>

    <div class="mt-6">
        <a asp-controller="Home" asp-action="Index" class="rounded-xl bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700">Back to Dashboard</a>
    </div>
</div>

